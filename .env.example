# ══════════════════════════════════════════════════════════════════════════════
# CyberAuth - Monorepo Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to backend/.env (for backend)
# 2. Copy this file to frontend/.env.local (for frontend)
# 3. Update values marked with [REQUIRED] and tokens/secrets
# 4. Never commit actual .env files - only .env.example
#
# ══════════════════════════════════════════════════════════════════════════════
# BACKEND CONFIGURATION (Python/FastAPI)
# ══════════════════════════════════════════════════════════════════════════════

# Environment mode
PRODUCTION=False

# ──── Database ────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password@localhost:5432/cyberauth

# ──── JWT / Authentication ────────────────────────────────────────────────────
# [REQUIRED] Secret key for signing JWT tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 random bytes (64 hex characters)
SECRET_KEY=your_64_character_random_secret_key_generated_with_secrets_module

# JWT algorithm (usually HS256)
ALGORITHM=HS256

# Access token expiration time (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration time (in days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──── Google OAuth 2.0 ────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
# Leave empty if not using Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ──── GitHub OAuth 2.0 ────────────────────────────────────────────────────────
# Get these from: https://github.com/settings/developers
# Leave empty if not using GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# ──── CORS & Frontend Configuration ────────────────────────────────────────────
# [REQUIRED] Allowed CORS origins (JSON array format)
# These are the frontend URLs that are allowed to make requests to the API
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# [REQUIRED] Frontend URL for redirects
FRONTEND_URL=http://localhost:3000

# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION (React/Vite)
# ══════════════════════════════════════════════════════════════════════════════
# NOTE: Frontend env variables in Vite MUST start with VITE_ prefix

# [REQUIRED] Backend API URL (must start with VITE_)
# This is where the frontend makes API requests to
VITE_API_URL=http://localhost:8000

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Advanced Configuration (uncomment to use)
# ══════════════════════════════════════════════════════════════════════════════

# Database connection pool settings
# DATABASE_POOL_SIZE=20
# DATABASE_POOL_MAX_OVERFLOW=10
# DATABASE_POOL_TIMEOUT=30

# Email configuration (for email verification/password reset)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=noreply@cyberauth.app

# Redis configuration (for production token blocklist and rate limiting)
# REDIS_URL=redis://localhost:6379/0

# Rate limiting configuration
# RATE_LIMIT_WINDOW=60
# RATE_LIMIT_MAX=5
# LOCKOUT_AFTER=10
# LOCKOUT_DURATION=900
